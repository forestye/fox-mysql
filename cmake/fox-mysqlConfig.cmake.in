@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# 在消费方机器上重新解析 libmysqlclient (路径可能与编译时不同):
# 通过 pkg-config 重建 PkgConfig::mysqlclient, 与导出的 fox-mysql::fox-mysql
# 内部记录的依赖名匹配, 这样链接时无需手工指定 libmysqlclient 路径。
find_dependency(PkgConfig REQUIRED)
if(NOT TARGET PkgConfig::mysqlclient)
    pkg_check_modules(mysqlclient REQUIRED IMPORTED_TARGET mysqlclient)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/fox-mysqlTargets.cmake")
check_required_components(fox-mysql)
